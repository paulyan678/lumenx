# New API gateway
NEWAPI_BASE_URL=https://www.moyu.cn/v1

# Active models (persisted defaults)
NEWAPI_CHAT_MODEL=deepseek-v4-flash
NEWAPI_IMAGE_MODEL=gpt-image-2
NEWAPI_VIDEO_MODEL=doubao-seedance-2-0-fast-260128

# One credential per approved model. Never reuse a key for another model.
NEWAPI_GPT_IMAGE_2_API_KEY=your_gpt_image_2_key
NEWAPI_SEEDANCE_2_API_KEY=your_seedance_2_key
NEWAPI_SEEDANCE_2_FAST_API_KEY=your_seedance_2_fast_key
NEWAPI_SEEDANCE_2_MINI_API_KEY=your_seedance_2_mini_key
NEWAPI_DEEPSEEK_V4_FLASH_API_KEY=your_deepseek_v4_flash_key
NEWAPI_QWEN_37_MAX_API_KEY=your_qwen_37_max_key
NEWAPI_DEEPSEEK_V4_PRO_API_KEY=your_deepseek_v4_pro_key

# Optional Alibaba Cloud OSS media mirror. AI generation remains New API-only.
OSS_ENABLE=false
ALIBABA_CLOUD_ACCESS_KEY_ID=your_aliyun_access_key_id_here
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_aliyun_access_key_secret_here
OSS_BUCKET_NAME=your_bucket_name
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_BASE_PATH=comic_gen/

# API service
API_HOST=127.0.0.1
API_PORT=17177

# Deployment security. Docker publishes only on loopback by default. Set the
# bind host to 0.0.0.0 only when a firewall/authenticated reverse proxy protects
# the service, and list every trusted remote browser origin explicitly.
LUMENX_DOCKER_BIND_HOST=127.0.0.1
LUMENX_CORS_ORIGINS=

# Local desktop/dev diagnostics remain available from loopback. Remote access
# to /debug, log tails, config paths, system details, and API docs is opt-in.
LUMENX_ENABLE_REMOTE_DIAGNOSTICS=false

# The desktop/static-export server also refuses non-loopback HOST values unless
# this separate network-exposure opt-in is enabled.
LUMENX_ALLOW_REMOTE_FRONTEND=false
