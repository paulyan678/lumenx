{
  "name": "lumenx",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20.9 <21"
  },
  "scripts": {
    "predev": "node scripts/dev-setup.js",
    "dev": "concurrently --kill-others-on-fail -n backend,frontend,open -c blue,green,cyan \"npm run dev:backend\" \"npm run dev:frontend\" \"node scripts/open-browser.js\"",
    "dev:backend": "node scripts/start-backend.js",
    "dev:frontend": "cd frontend && npm run dev",
    "check:duplicates": "python3 scripts/check_duplicate_filenames.py"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3"
  }
}
