# -*- mode: python ; coding: utf-8 -*-
# PyInstaller Spec 文件模板
# 这是一个高级配置模板，供需要自定义打包的用户使用

import os
import shutil
import subprocess
import sys
from PyInstaller.utils.hooks import collect_all

block_cipher = None

# 项目根目录
ROOT_DIR = os.path.abspath('.')

FFMPEG_NAME = 'ffmpeg.exe' if sys.platform == 'win32' else 'ffmpeg'
FFMPEG_PATH = os.environ.get('LUMENX_FFMPEG_BINARY') or shutil.which(FFMPEG_NAME)
if not FFMPEG_PATH or not os.path.isfile(FFMPEG_PATH):
    raise FileNotFoundError(
        'A runnable FFmpeg was not found. Install FFmpeg or set '
        'LUMENX_FFMPEG_BINARY before packaging.'
    )
FFMPEG_PATH = os.path.abspath(FFMPEG_PATH)
try:
    subprocess.run(
        [FFMPEG_PATH, '-version'],
        check=True,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
except (OSError, subprocess.CalledProcessError) as exc:
    raise RuntimeError(f'FFmpeg cannot run: {FFMPEG_PATH}') from exc

ICON_PATH = 'icon.icns' if sys.platform == 'darwin' else 'icon.ico'
if not os.path.isfile(ICON_PATH):
    ICON_PATH = None

# 收集所有数据文件
datas = [
    ('static', 'static'),
    ('src/apps/comic_gen/style_presets.json', 'src/apps/comic_gen'),
    (
        'config/model_catalog/generated/model_catalog.json',
        'config/model_catalog/generated',
    ),
]

# 收集所有隐藏导入
hiddenimports = [
    # Uvicorn
    'uvicorn.logging',
    'uvicorn.loops',
    'uvicorn.loops.auto',
    'uvicorn.protocols',
    'uvicorn.protocols.http',
    'uvicorn.protocols.http.auto',
    'uvicorn.protocols.websockets',
    'uvicorn.protocols.websockets.auto',
    'uvicorn.lifespan',
    'uvicorn.lifespan.on',
    # WebView
    'webview',
    # Web Framework
    'starlette',
    'starlette.staticfiles',
    'fastapi',
    'pydantic',
    # New API (OpenAI-compatible)
    'openai',
    # Local audio separation
    'demucs',
    'demucs.pretrained',
    'demucs.separate',
    'soundfile',
    # 其他
    'yaml',
    'dotenv',
    'httptools',
    'uvloop',
    'requests',
    'multipart',
]
binaries = [(FFMPEG_PATH, '.')]

# 自动收集包的所有内容
for package in ['uvicorn', 'fastapi', 'starlette', 'pydantic', 'demucs']:
    tmp_datas, tmp_binaries, tmp_hiddenimports = collect_all(package)
    datas += tmp_datas
    binaries += tmp_binaries
    hiddenimports += tmp_hiddenimports

a = Analysis(
    ['main.py'],
    pathex=[ROOT_DIR],
    binaries=binaries,
    datas=datas,
    hiddenimports=hiddenimports,
    hookspath=['.pyinstaller-hooks'],
    hooksconfig={},
    runtime_hooks=[],
    excludes=[
        # 排除不需要的模块以减小体积
        'matplotlib',
        'PIL',
        'tkinter',
    ],
    win_no_prefer_redirects=False,
    win_private_assemblies=False,
    cipher=block_cipher,
    noarchive=False,
)

pyz = PYZ(a.pure, a.zipped_data, cipher=block_cipher)

exe = EXE(
    pyz,
    a.scripts,
    a.binaries,
    a.zipfiles,
    a.datas,
    [],
    name='LumenX Studio',
    debug=False,
    bootloader_ignore_signals=False,
    strip=False,
    upx=True,  # 使用 UPX 压缩（需要安装 UPX）
    upx_exclude=[],
    runtime_tmpdir=None,
    console=False,  # 不显示控制台窗口
    disable_windowed_traceback=False,
    argv_emulation=False,
    target_arch=None,
    codesign_identity=None,
    entitlements_file=None,
    # macOS 使用 .icns，Windows 使用 .ico
    icon=ICON_PATH,
)

# macOS 应用包配置
if sys.platform == 'darwin':
    app = BUNDLE(
        exe,
        name='LumenX Studio.app',
        icon=ICON_PATH,
        bundle_identifier='studio.lumenx.desktop',
        info_plist={
            'NSPrincipalClass': 'NSApplication',
            'NSHighResolutionCapable': 'True',
            'CFBundleShortVersionString': '1.0.0',
            'CFBundleVersion': '1.0.0',
        },
    )
